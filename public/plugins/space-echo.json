{
  "id": "space-echo",
  "name": "Space Echo",
  "author": "Strange Arcade",
  "description": "Long feedback delay through a darkening filter — like a Roland RE-201 drifting through deep space. Hand speed controls how much signal feeds back into itself.",
  "version": "1.0",
  "nodes": [
    { "id": "tapeDelay", "type": "FeedbackDelay", "params": { "delayTime": 0.42, "feedback": 0.55, "wet": 0.75 } },
    { "id": "darkFilter", "type": "Filter", "params": { "frequency": 2800, "type": "lowpass", "rolloff": -24 } },
    { "id": "spaceVerb", "type": "Reverb", "params": { "decay": 6.0, "preDelay": 0.05, "wet": 0.35 } }
  ],
  "chain": ["input", "tapeDelay", "darkFilter", "spaceVerb", "output"],
  "controls": [
    { "id": "delayTime", "target": "tapeDelay.delayTime", "label": "Tape Speed", "type": "slider", "min": 0.1, "max": 1.2, "default": 0.42 },
    { "id": "feedback", "target": "tapeDelay.feedback", "label": "Echo Feedback", "type": "slider", "min": 0, "max": 0.92, "default": 0.55 },
    { "id": "darkness", "target": "darkFilter.frequency", "label": "Darkness", "type": "slider", "min": 500, "max": 8000, "default": 2800 }
  ],
  "gestures": [
    { "source": "hand_speed", "target": "tapeDelay.feedback", "range": [0, 0.92] },
    { "source": "hand_x", "target": "tapeDelay.delayTime", "range": [0.1, 1.2] }
  ]
}
