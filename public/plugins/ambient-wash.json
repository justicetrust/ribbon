{
  "id": "ambient-wash",
  "name": "Ambient Wash",
  "author": "Strange Arcade",
  "description": "Heavy reverb, lush chorus, and slow auto-panning dissolve any sound into a wide, drifting ambient cloud. Pull your hands apart to lengthen the reverb tail into infinity.",
  "version": "1.0",
  "nodes": [
    { "id": "cloudVerb", "type": "Reverb", "params": { "decay": 8.0, "preDelay": 0.04, "wet": 0.85 } },
    { "id": "lushChorus", "type": "Chorus", "params": { "frequency": 0.6, "delayTime": 3.5, "depth": 0.7, "wet": 0.6 } },
    { "id": "widePan", "type": "AutoPanner", "params": { "frequency": 0.2, "wet": 0.9 } }
  ],
  "chain": ["input", "lushChorus", "cloudVerb", "widePan", "output"],
  "controls": [
    { "id": "decay", "target": "cloudVerb.decay", "label": "Reverb Decay", "type": "slider", "min": 1, "max": 20, "default": 8 },
    { "id": "chorusDepth", "target": "lushChorus.depth", "label": "Chorus Depth", "type": "slider", "min": 0, "max": 1, "default": 0.7 },
    { "id": "panRate", "target": "widePan.frequency", "label": "Pan Speed", "type": "slider", "min": 0.05, "max": 2, "default": 0.2 }
  ],
  "gestures": [
    { "source": "hand_distance", "target": "cloudVerb.decay", "range": [1, 20] },
    { "source": "hand_distance", "target": "cloudVerb.wet", "range": [0.3, 1] }
  ]
}
